{
  "name": "@careeright/jobs",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "apply:plan": "tsx src/job-apply-runner.ts",
    "apply:attempt": "tsx src/job-apply-attempt.ts",
    "cleanup:solo-user": "tsx src/delete-solo-user-data.ts"
  },
  "dependencies": {
    "@careeright/domain": "workspace:*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
