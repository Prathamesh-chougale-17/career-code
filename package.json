{
  "name": "careeright",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "mcp": "pnpm --filter @careeright/mcp build && pnpm --filter @careeright/mcp stdio",
    "mcp:package:build": "pnpm --filter careeright-mcp build",
    "mcp:package:pack": "pnpm run mcp:package:build && pnpm --filter careeright-mcp exec npm pack --dry-run",
    "mcp:package:publish": "pnpm run mcp:package:build && pnpm --filter careeright-mcp exec npm publish",
    "jobs:apply:attempt": "pnpm --filter @careeright/jobs apply:attempt",
    "jobs:apply:plan": "pnpm --filter @careeright/jobs apply:plan",
    "cleanup:solo-user": "pnpm --filter @careeright/jobs cleanup:solo-user"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2",
      "csstype": "3.2.3"
    }
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
