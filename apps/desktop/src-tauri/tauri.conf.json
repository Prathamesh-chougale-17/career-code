{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Careeright",
  "version": "1.0.4",
  "identifier": "com.profeonix.careeright.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Careeright",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["careeright-desktop"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDNDRENUJDNjBFMTRCMgpSV1N5RkE3R1cwM0VEU25KQ2IvNFBGNi9WUW8rZFRuRjJsMVF2eXBWSjZPV0NrU0RTc3RpQVlFaAo=",
      "endpoints": [
        "https://github.com/Prathamesh-chougale-17/career-code/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
