# MongoDB Atlas connection string. Leave unset to use the local memory store.
MONGODB_URI=
MONGODB_DB=careeright

# Better Auth secret and canonical URL for authenticated flows.
# BETTER_AUTH_* remains supported for compatibility with the original app.
CAREERIGHT_AUTH_SECRET=
CAREERIGHT_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional for local stdio MCP clients. Use a user token created in /dashboard/mcp-tools.
CAREERIGHT_MCP_TOKEN=

# AI model identifier used by the Vercel AI SDK task breakdown flow.
# When unset, task breakdown proposals fail instead of using generated dummy data.
AI_TASK_MODEL=

# Optional AI model for richer job fit explanations.
AI_JOB_MATCH_MODEL=

# Optional future Langfuse tracing configuration.
# The current app works without these values.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com
